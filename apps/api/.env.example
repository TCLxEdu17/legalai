DATABASE_URL=postgresql://legalai:legalai_secret@localhost:5432/legal_ai
REDIS_URL=redis://localhost:6379

JWT_SECRET=mude_este_secret_em_producao_32chars_min
JWT_REFRESH_SECRET=mude_este_refresh_secret_em_producao
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

AI_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536

ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-6

UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# Cloudflare R2 Storage (opcional — fallback para disco local se não configurado)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=legalai-uploads
R2_PUBLIC_URL=https://pub-xxxxx.r2.dev

NODE_ENV=development
API_PORT=3001
# Em produção: CORS_ORIGINS=https://seudominio.com
CORS_ORIGINS=http://localhost:3000

# RAG
RAG_SIMILARITY_THRESHOLD=0.30
RAG_MAX_CHUNKS=5

ADMIN_EMAIL=admin@legalai.com.br
# Troque em produção
ADMIN_PASSWORD=Admin@123456
