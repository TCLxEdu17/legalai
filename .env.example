# ============================================================
# DATABASE
# ============================================================
POSTGRES_USER=legalai
POSTGRES_PASSWORD=legalai_secret
POSTGRES_DB=legal_ai
DATABASE_URL=postgresql://legalai:legalai_secret@localhost:5432/legal_ai

# ============================================================
# REDIS (para filas futuras)
# ============================================================
REDIS_URL=redis://localhost:6379

# ============================================================
# JWT
# ============================================================
JWT_SECRET=mude_este_secret_em_producao_use_32chars_min
JWT_REFRESH_SECRET=mude_este_refresh_secret_em_producao
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ============================================================
# AI PROVIDER
# ============================================================
# Opções: openai | anthropic
AI_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536

# Anthropic (alternativa)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-6

# ============================================================
# UPLOAD
# ============================================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# ============================================================
# FRONTEND (Next.js)
# ============================================================
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXTAUTH_SECRET=mude_este_nextauth_secret
NEXTAUTH_URL=http://localhost:3000

# ============================================================
# APP
# ============================================================
NODE_ENV=development
API_PORT=3001
# Em produção: CORS_ORIGINS=https://seudominio.com
CORS_ORIGINS=http://localhost:3000

# ============================================================
# RAG
# ============================================================
RAG_SIMILARITY_THRESHOLD=0.30
RAG_MAX_CHUNKS=5

# ============================================================
# SENTRY (optional — error monitoring)
# ============================================================
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ============================================================
# SEED (primeiro boot)
# ============================================================
ADMIN_EMAIL=admin@legalai.com.br
# Troque em produção
ADMIN_PASSWORD=Admin@123456
